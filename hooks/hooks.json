{
    "description": "GG plugin hooks — destructive command guard and audit logging",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$GG_PLUGIN_ROOT/hooks/pre-tool-use.sh\""
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": ".*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$GG_PLUGIN_ROOT/hooks/post-tool-use.sh\""
                    }
                ]
            }
        ]
    }
}
